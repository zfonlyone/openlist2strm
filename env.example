# Runtime
TZ=Asia/Shanghai
CONFIG_PATH=/config/config.yml

# Compose mapping
OPENLIST2STRM_BIND_IP=127.0.0.1
OPENLIST2STRM_WEB_PORT=9527
OPENLIST2STRM_CONFIG_DIR=/etc/media-server/openlist2strm/config
OPENLIST2STRM_DATA_DIR=/etc/media-server/openlist2strm/data
OPENLIST2STRM_STRM_DIR=/etc/media-server/openlist2strm/data/strm

# OpenList
OPENLIST_HOST=http://openlist:5244
OPENLIST_TOKEN=
OPENLIST_TIMEOUT=30

# Paths
# Multiple source paths: comma-separated, e.g. /115/电影,/115/电视剧
PATHS_SOURCE=/115/流媒体
PATHS_OUTPUT=/strm

# STRM
STRM_MODE=path
STRM_URL_ENCODE=true
STRM_KEEP_STRUCTURE=true
STRM_OUTPUT_PATH=/strm

# Web
WEB_AUTH_ENABLED=true
WEB_AUTH_USERNAME=admin
# 建议直接在 /etc/media-server/openlist2strm/.env 中维护哈希值
WEB_AUTH_PASSWORD=
# 如已在 .env 中设置，Web 界面不会覆盖该值
WEB_AUTH_API_TOKEN=

# Emby
EMBY_ENABLED=false
EMBY_HOST=
EMBY_API_KEY=
EMBY_LIBRARY_ID=
EMBY_NOTIFY_ON_SCAN=true

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7
LOG_COLORIZE=true
