# Runtime
TZ=Asia/Shanghai
CONFIG_PATH=/config/config.yml

# Compose mapping
OPENLIST2STRM_BIND_IP=127.0.0.1
OPENLIST2STRM_WEB_PORT=9527
OPENLIST2STRM_CONFIG_DIR=./config
OPENLIST2STRM_DATA_DIR=./data
OPENLIST2STRM_STRM_DIR=./movie/strm

# OpenList
OPENLIST_HOST=http://openlist:5244
OPENLIST_TOKEN=
OPENLIST_TIMEOUT=30

# Paths
# Multiple source paths: comma-separated, e.g. /115/电影,/115/电视剧
PATHS_SOURCE=/115/流媒体
PATHS_OUTPUT=/strm

# STRM
STRM_MODE=path
STRM_URL_ENCODE=true
STRM_KEEP_STRUCTURE=true
STRM_OUTPUT_PATH=/strm

# Web
WEB_AUTH_ENABLED=true
WEB_AUTH_USERNAME=admin
# 支持填写明文；建议首次登录后在设置页修改，并保存为哈希密码
WEB_AUTH_PASSWORD=
# 可在设置页自动生成，格式为 sk-xxxxx
WEB_AUTH_API_TOKEN=

# Emby
EMBY_ENABLED=false
EMBY_HOST=
EMBY_API_KEY=
EMBY_LIBRARY_ID=
EMBY_NOTIFY_ON_SCAN=true

# Logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=7
LOG_COLORIZE=true
